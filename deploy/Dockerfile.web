# deploy/Dockerfile.web — Next.js 15, multi-stage, standalone output.
# Build from repo root:
#   docker build -f deploy/Dockerfile.web -t intern-web .
#
# Assumes web/next.config.* sets `output: "standalone"` (standard Next 15 layout).
# If web/ isn't buildable yet, use the `web-dev` compose profile instead
# (npm run dev with a bind mount) — see deploy/docker-compose.yml.

# ---- deps ----
FROM node:20-alpine AS deps
WORKDIR /app
COPY web/package.json web/package-lock.json* ./
# npm ci when a lockfile exists, plain install otherwise (web/ is still landing)
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# ---- build ----
FROM node:20-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY web/ ./
RUN mkdir -p public
ARG API_ORIGIN=http://api:8000
ENV API_ORIGIN=$API_ORIGIN
RUN npm run build

# ---- run ----
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000
CMD ["node", "server.js"]
